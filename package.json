{
  "name": "audiobook-creator",
  "version": "1.0.0",
  "description": "Lecteur et créateur d'audiobooks avec synthèse vocale",
  "main": "main.js",
  "author": "Mathias Gero",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "dist:all": "electron-builder --win --mac --linux --publish never",
    "release": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.mathiasgero.audiobookcreator",
    "productName": "AudioBook Creator",
    "copyright": "Copyright © 2026 Mathias Gero",
    "files": [
      "index.html",
      "main.js"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AudioBook Creator"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education"
    }
  }
}
